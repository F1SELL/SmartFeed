# HTTP Server
CORE_HTTP_PORT=8080

# PostgreSQL
PG_DSN=postgres://smartfeed:secret@localhost:55432/smartfeed_db?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_POST_CREATED=post_created
KAFKA_GROUP_FEED=feed-worker
KAFKA_GROUP_AI=ai-worker

# Security
JWT_SECRET=your_super_secret_key_change_in_prod

# LLM (AI Worker)
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SEC=15
